---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { site } from '../../data/site';
import { images } from '../../data/images';
import { t } from '../../i18n/ui';

const lang = 'en';
const strings = t(lang);
const waText = encodeURIComponent('Hello, I would like information about Agriturismo Villalba');
const waUrl = `https://wa.me/393333570420?text=${waText}`;
---

<BaseLayout
  lang={lang}
  page="contatti"
  title="Contact"
  description="Contact Agriturismo Villalba in San Marco Villalba, Arezzo. Phone, email, WhatsApp and Booking for reservations, dinners and experiences."
>
  <PageHero
    title="Contact us"
    subtitle="We are here to answer your questions"
    image={images.garden}
  />

  <section class="section section--white">
    <div class="container contact-page">
      <div class="contact-page__intro">
        <h2 class="section__title">Get in touch</h2>
        <p class="section__lead">
          For apartment bookings use Booking. For dinners, aperitifs, cooking classes, special
          breakfasts or any other request, contact us directly.
        </p>
      </div>

      <div class="contact-cards">
        <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="contact-card">
          <div class="contact-card__icon">📞</div>
          <h3>Phone</h3>
          <p>{site.phoneDisplay}</p>
        </a>

        <a href={`mailto:${site.email}`} class="contact-card">
          <div class="contact-card__icon">✉️</div>
          <h3>Email</h3>
          <p>{site.email}</p>
        </a>

        <a href={waUrl} class="contact-card" target="_blank" rel="noopener">
          <div class="contact-card__icon">💬</div>
          <h3>WhatsApp</h3>
          <p>{strings.whatsapp}</p>
        </a>

        <a href={site.bookingUrl} class="contact-card" target="_blank" rel="noopener">
          <div class="contact-card__icon">🏨</div>
          <h3>Bookings</h3>
          <p>{strings.book}</p>
        </a>

        <a href={site.mapsLink} class="contact-card" target="_blank" rel="noopener">
          <div class="contact-card__icon">📍</div>
          <h3>Address</h3>
          <p>
            {site.address}<br />
            {site.city}
          </p>
        </a>
      </div>

      <p class="contact-page__legal">
        {strings.legal}: {site.address}, {site.city}<br />
        {strings.vat} {site.vat}
      </p>

      <div class="map-embed">
        <iframe
          src={site.mapsEmbed}
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Agriturismo Villalba map"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
