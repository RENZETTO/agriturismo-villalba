---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site';
import { images } from '../data/images';
import { t } from '../i18n/ui';

const lang = 'it';
const strings = t(lang);
const waText = encodeURIComponent('Buongiorno, vorrei informazioni su Agriturismo Villalba');
const waUrl = `https://wa.me/393333570420?text=${waText}`;
---

<BaseLayout
  lang={lang}
  page="contatti"
  title="Contatti"
  description="Contatta Agriturismo Villalba a San Marco Villalba, Arezzo. Telefono, email, WhatsApp e Booking per prenotazioni, cene ed esperienze."
>
  <PageHero
    title="Contatti"
    subtitle="Siamo qui per rispondere alle tue domande"
    image={images.garden}
  />

  <section class="section section--white">
    <div class="container contact-page">
      <div class="contact-page__intro">
        <h2 class="section__title">Scrivici o chiamaci</h2>
        <p class="section__lead">
          Per prenotazioni dell'appartamento usa Booking. Per cene, aperitivi, corsi di cucina,
          colazioni speciali o qualsiasi altra richiesta, contattaci direttamente.
        </p>
      </div>

      <div class="contact-cards">
        <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="contact-card">
          <div class="contact-card__icon">📞</div>
          <h3>Telefono</h3>
          <p>{site.phoneDisplay}</p>
        </a>

        <a href={`mailto:${site.email}`} class="contact-card">
          <div class="contact-card__icon">✉️</div>
          <h3>Email</h3>
          <p>{site.email}</p>
        </a>

        <a href={waUrl} class="contact-card" target="_blank" rel="noopener">
          <div class="contact-card__icon">💬</div>
          <h3>WhatsApp</h3>
          <p>{strings.whatsapp}</p>
        </a>

        <a href={site.bookingUrl} class="contact-card" target="_blank" rel="noopener">
          <div class="contact-card__icon">🏨</div>
          <h3>Prenotazioni</h3>
          <p>{strings.book}</p>
        </a>

        <a href={site.mapsLink} class="contact-card" target="_blank" rel="noopener">
          <div class="contact-card__icon">📍</div>
          <h3>Indirizzo</h3>
          <p>
            {site.address}<br />
            {site.city}
          </p>
        </a>
      </div>

      <p class="contact-page__legal">
        {strings.legal}: {site.address}, {site.city}<br />
        {strings.vat} {site.vat}
      </p>

      <div class="map-embed">
        <iframe
          src={site.mapsEmbed}
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mappa Agriturismo Villalba"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
