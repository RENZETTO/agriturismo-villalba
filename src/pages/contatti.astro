---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
import { site } from '../data/site';
import { images } from '../data/images';
import { t } from '../i18n/ui';

const lang = 'it';
const strings = t(lang);
const waText = encodeURIComponent('Buongiorno, vorrei informazioni su Agriturismo Villalba');
const waUrl = `https://wa.me/393333570420?text=${waText}`;
---

<BaseLayout
  lang={lang}
  page="contatti"
  title="Contatti"
  description="Contatta Agriturismo Villalba a San Marco Villalba, Arezzo. Telefono, email, WhatsApp e modulo per richieste su prenotazioni, cene e esperienze."
>
  <PageHero
    title="Contatti"
    subtitle="Siamo qui per rispondere alle tue domande"
    image={images.garden}
  />

  <section class="section section--white">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2 class="section__title" style="font-size: 2rem; margin-bottom: 2rem;">
            Scrivici o chiamaci
          </h2>
          <p class="section__lead" style="margin-bottom: 2rem;">
            Per prenotazioni dell'appartamento usa Booking. Per cene, aperitivi, corsi di cucina,
            colazioni speciali o qualsiasi altra richiesta, contattaci direttamente.
          </p>

          <div class="contact-info__item">
            <div class="contact-info__icon">📞</div>
            <div>
              <h4>Telefono</h4>
              <a href={`tel:${site.phone.replace(/\s/g, '')}`}>{site.phoneDisplay}</a>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon">✉️</div>
            <div>
              <h4>Email</h4>
              <a href={`mailto:${site.email}`}>{site.email}</a>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon">💬</div>
            <div>
              <h4>WhatsApp</h4>
              <a href={waUrl} target="_blank" rel="noopener">{strings.whatsapp}</a>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon">📍</div>
            <div>
              <h4>Indirizzo</h4>
              <p>
                {site.address}<br />
                {site.city}
              </p>
              <a href={site.mapsLink} target="_blank" rel="noopener" style="font-size: 0.9rem;">
                Apri in Google Maps →
              </a>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon">🏨</div>
            <div>
              <h4>Prenotazioni</h4>
              <a href={site.bookingUrl} target="_blank" rel="noopener">
                {strings.book} →
              </a>
            </div>
          </div>

          <p style="margin-top: 2rem; font-size: 0.9rem; color: var(--color-text-muted);">
            {strings.legal}: {site.address}, {site.city}<br />
            {strings.vat} {site.vat}
          </p>
        </div>

        <ContactForm lang={lang} />
      </div>

      <div class="map-embed">
        <iframe
          src={site.mapsEmbed}
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mappa Agriturismo Villalba"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
