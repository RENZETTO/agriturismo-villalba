---
import type { Lang } from '../data/site';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const strings = t(lang);

const subjects =
  lang === 'it'
    ? [
        { value: 'prenotazione', label: 'Informazioni prenotazione' },
        { value: 'cena', label: 'Richiesta cena' },
        { value: 'aperitivo', label: 'Aperitivo con jacuzzi' },
        { value: 'colazione', label: 'Colazione / crostata' },
        { value: 'corso-cucina', label: 'Corso di cucina contadina' },
        { value: 'altro', label: 'Altro' },
      ]
    : [
        { value: 'booking', label: 'Booking information' },
        { value: 'dinner', label: 'Dinner request' },
        { value: 'aperitif', label: 'Aperitif with jacuzzi' },
        { value: 'breakfast', label: 'Breakfast / tart' },
        { value: 'cooking', label: 'Farmhouse cooking class' },
        { value: 'other', label: 'Other' },
      ];
---

<form
  class="contact-form"
  name="contact"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  action={lang === 'it' ? '/grazie' : '/en/thank-you'}
>
  <input type="hidden" name="form-name" value="contact" />
  <p hidden>
    <label>Non compilare: <input name="bot-field" /></label>
  </p>

  <div class="form-group">
    <label for="name">{strings.name} *</label>
    <input type="text" id="name" name="name" required />
  </div>

  <div class="form-group">
    <label for="email">{strings.email} *</label>
    <input type="email" id="email" name="email" required />
  </div>

  <div class="form-group">
    <label for="phone">{strings.phone}</label>
    <input type="tel" id="phone" name="phone" />
  </div>

  <div class="form-group">
    <label for="subject">{strings.subject}</label>
    <select id="subject" name="subject">
      {subjects.map((s) => (
        <option value={s.value}>{s.label}</option>
      ))}
    </select>
  </div>

  <div class="form-group">
    <label for="message">{strings.message} *</label>
    <textarea id="message" name="message" required></textarea>
  </div>

  <div class="form-checkbox">
    <input type="checkbox" id="privacy" name="privacy" required />
    <label for="privacy">{strings.privacy}</label>
  </div>

  <button type="submit" class="btn btn--olive" style="margin-top: 1.5rem; width: 100%;">
    {strings.send}
  </button>

  <p class="form-note">{strings.formNote}</p>
</form>
