---
import { site } from '../data/site';
import type { Lang } from '../data/site';
import type { PageKey } from '../i18n/ui';
import { nav, pagePath, switchPath, t } from '../i18n/ui';

interface Props {
  lang: Lang;
  page: PageKey;
}

const { lang, page } = Astro.props;
const strings = t(lang);
---

<header class="header">
  <div class="container header__inner">
    <a href={pagePath(lang, 'home')} class="header__logo">
      <img
        src="/logo_villalba.png"
        alt={site.name}
        width="56"
        height="56"
        class="header__logo-img"
      />
      <span class="header__logo-text">
        Villalba <span>Agriturismo</span>
      </span>
    </a>

    <div class="header__mobile-end">
      <a href={switchPath(lang, page)} class="header__lang header__lang--bar" aria-label={lang === 'it' ? 'Switch to English' : 'Passa all\'italiano'}>
        {strings.langSwitch}
      </a>
      <button class="header__toggle" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <nav class="header__nav">
      <ul class="header__links">
        {nav[lang].map((item) => (
          <li>
            <a
              href={pagePath(lang, item.page)}
              class:list={{ active: item.page === page }}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <div class="header__actions">
        <a href={switchPath(lang, page)} class="header__lang header__lang--nav" aria-label={lang === 'it' ? 'Switch to English' : 'Passa all\'italiano'}>
          {strings.langSwitch}
        </a>
        <a href={site.bookingUrl} class="btn btn--primary" target="_blank" rel="noopener">
          {strings.book}
        </a>
      </div>
    </nav>
  </div>
</header>
