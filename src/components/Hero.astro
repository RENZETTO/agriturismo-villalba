---
import { site } from '../data/site';
import { t } from '../i18n/ui';
import type { Lang } from '../data/site';
import { pagePath } from '../i18n/ui';

interface Props {
  lang: Lang;
  eyebrow: string;
  title: string;
  subtitle: string;
  image: string;
}

const { lang, eyebrow, title, subtitle, image } = Astro.props;
const strings = t(lang);
---

<section class="hero">
  <div class="hero__bg" style={`background-image: url('${image}')`}></div>
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <p class="hero__eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="hero__subtitle">{subtitle}</p>
    <div class="hero__actions">
      <a href={site.bookingUrl} class="btn btn--primary" target="_blank" rel="noopener">
        {strings.bookCta}
      </a>
      <a href={pagePath(lang, 'esperienze')} class="btn btn--outline">
        {strings.learnMore}
      </a>
    </div>
  </div>
  <div class="hero__scroll">{lang === 'it' ? 'Scorri' : 'Scroll'}</div>
</section>
